{
  "$schema": "https://unpkg.com/knip/schema.json",
  "entry": [
    "scripts/**/*.ts",
    "home/**/*.ts",
    "!home/lib/**/*.ts",
    "!home/etc/**/*.ts",
    "!home/bin/broker/api.ts",
    "!home/bin/broker/forecaster-4s.ts",
    "!home/bin/broker/forecaster-trend.ts",
    "!home/bin/broker/trade.ts",
    "!home/bin/contracts/algorithms.ts",
    "!home/bin/contracts/mapper.ts",
    "!home/bin/self/aug/factions.ts",
    "!home/boot/cheaty-data.ts",
    "!home/boot/util.ts"
  ],
  "project": ["scripts/**/*.ts", "home/**/*.ts"],
  "ignoreDependencies": ["d3-drag", "d3-force", "d3-selection", "prettier"],
  "ignore": ["home/lib/d3.ts", "home/lib/colors.ts"]
}
